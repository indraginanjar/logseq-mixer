{
  "name": "logseq-mixer",
  "version": "0.1.4",
  "author": "Indra Ginanjar",
  "description": "Autonomous AI agent for Logseq — hybrid RAG search, persistent memory, direct graph editing, and MCP tool integration powered by 100+ LLM providers",
  "main": "index.html",
  "effect": "true",

  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "build": "tsc && vite build",
    "preview": "vite preview",
    "postbuild": "node -e \"const fs=require('fs'),p=require('path');fs.copyFileSync('package.json','dist/package.json');if(fs.existsSync('README.md'))fs.copyFileSync('README.md','dist/README.md');if(fs.existsSync('logseq.png'))fs.copyFileSync('logseq.png','dist/logseq.png');if(fs.existsSync('icon.png'))fs.copyFileSync('icon.png','dist/icon.png');if(fs.existsSync('icon-dark-transparent.png'))fs.copyFileSync('icon-dark-transparent.png','dist/icon-dark-transparent.png');if(process.env.CI!=='true'){const d=p.join(require('os').homedir(),'.logseq/plugins/logseq-mixer');fs.mkdirSync(d,{recursive:true});fs.cpSync('dist',d,{recursive:true})}\"",
    "dev": "yarn && yarn build && yarn postbuild"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.1.0",
    "@fortawesome/free-solid-svg-icons": "^6.1.0",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@logseq/libs": "^0.0.17",
    "@radix-ui/colors": "^0.1.8",
    "@radix-ui/react-collapsible": "^0.1.5",
    "@radix-ui/react-toolbar": "^0.1.4",
    "@stitches/react": "^1.2.6",
    "hnswlib-wasm": "^0.8.2",
    "js-tiktoken": "^1.0.21",
    "mermaid": "^11.4.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-markdown": "8.0.7",
    "recoil": "^0.7.7",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@logseq/libs": "^0.0.1-alpha.29",
    "@testing-library/jest-dom": "^5",
    "@testing-library/react": "^12",
    "@types/react": "^17.0.33",
    "@types/react-dom": "^17.0.10",
    "@vitejs/plugin-react": "^1.0.7",
    "fast-check": "^4.6.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.5.0",
    "vite": "^2.7.2",
    "vite-tsconfig-paths": "^3.3.17",
    "vitest": "^0.34.6"
  },
  "browserslist": [
    "chrome 80"
  ],
  "logseq": {
    "id": "logseq-mixer",
    "title": "Mixer",
    "icon": "logseq.png"
  }
}
